# Copy to .env.local and fill in. Never commit real secrets.

NODE_ENV=development
LOG_LEVEL=info

# Public site URL (used for canonical URLs, OG metadata)
NEXT_PUBLIC_SITE_URL=https://example.com

# Analytics (optional)
NEXT_PUBLIC_ANALYTICS_DOMAIN=

# Email — SMTP provider (used when siteConfig.providers.email === 'smtp')
# For Gmail: use an App Password, not your account password.
# https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
EMAIL_FROM=you@example.com
EMAIL_TO=you@example.com

# Email — Resend (used when siteConfig.providers.email === 'resend')
RESEND_API_KEY=

# Errors (optional)
SENTRY_DSN=

# Server Action ID encryption key — pins Server Action IDs across builds so
# clients don't get UnrecognizedActionError after a redeploy. Generate with:
#   openssl rand -base64 32
# Same value must be set in Vercel for Production, Preview, and Development.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
